<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:SpotifyPlaylistCleaner_DotNET.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:asyncImage="using:AsyncImageLoader"
        xmlns:converters="using:SpotifyPlaylistCleaner_DotNET.Converters"
        xmlns:models="using:SpotifyPlaylistCleaner_DotNET.Models"
        mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="600"
        MinWidth="800" MinHeight="500"
        x:Class="SpotifyPlaylistCleaner_DotNET.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/Icons/icon.ico"
        Title="Spotify Playlist Cleaner"
        Background="#121212">

    <Design.DataContext>
        <vm:MainWindowViewModel />
    </Design.DataContext>

    <Window.Resources>
        <DataTemplate x:DataType="models:TrackModel" x:Key="DeleteButtonTemplate">
            <Button Background="Transparent"
                    BorderThickness="0"
                    Width="32"
                    Height="32"
                    Padding="0"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Command="{Binding $parent[DataGrid].((vm:MainWindowViewModel)DataContext).TrackListViewModel.DeleteTrackCommand, FallbackValue={x:Null}}"
                    CommandParameter="{Binding}"
                    ToolTip.Tip="Delete Track">
                <Viewbox Width="16" Height="16"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center"
                         Margin="-2,-2,2,2">
                    <Path
                        Data="M6,19C6,20.1 6.9,21 8,21H16C17.1,21 18,20.1 18,19V7H6V19M19,4H15.5L14.5,3H9.5L8.5,4H5V6H19V4Z"
                        Fill="#ff5252" />
                </Viewbox>
            </Button>
        </DataTemplate>
    </Window.Resources>

    <Grid RowDefinitions="Auto,*">
        <!-- Header -->
        <Border Grid.Row="0" Grid.ColumnSpan="2" Background="#1DB954"
                Padding="20" BoxShadow="0 1 10 0 #20000000">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <!-- App Title (Left) -->
                <StackPanel Orientation="Horizontal" Grid.Column="0" Spacing="10" VerticalAlignment="Center">
                    <TextBlock Text="Spotify Playlist Cleaner" FontSize="20" FontWeight="Bold" Foreground="White" />
                </StackPanel>

                <!-- Status Message (Center - properly aligned) -->
                <Grid Grid.Column="0" Grid.ColumnSpan="3" VerticalAlignment="Center">
                    <TextBlock Text="{Binding StatusMessage}"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"
                               Foreground="White"
                               MaxWidth="500" />
                </Grid>

                <!-- Right side controls -->
                <Panel Grid.Column="2">
                    <!-- Desktop layout (horizontal) -->
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Button Command="{Binding TrackListViewModel.RefreshTracksCommand}"
                                IsEnabled="{Binding IsAuthenticated}"
                                ToolTip.Tip="Refresh Tracks"
                                Padding="10,5"
                                Background="#121212"
                                Foreground="White">
                            <StackPanel Orientation="Horizontal" Spacing="5">
                                <Path
                                    Data="M17.65,6.35C16.2,4.9 14.21,4 12,4A8,8 0 0,0 4,12A8,8 0 0,0 12,20A8,8 0 0,0 20,12H18A6,6 0 0,1 12,18A6,6 0 0,1 6,12A6,6 0 0,1 12,6C13.66,6 15.14,6.69 16.22,7.78L13,11H20V4L17.65,6.35Z"
                                    Fill="White" Width="16" Height="16" Stretch="Uniform" />
                                <TextBlock Text="Refresh Tracks" />
                            </StackPanel>
                        </Button>

                        <!-- Login Button -->
                        <Button Content="Login with Spotify"
                                Command="{Binding AuthenticateCommand}"
                                IsEnabled="{Binding !IsAuthenticating}"
                                IsVisible="{Binding !IsAuthenticated}"
                                Padding="10,5"
                                Background="#121212"
                                Foreground="White" />
                    </StackPanel>
                </Panel>
            </Grid>
        </Border>

        <!-- Content area with sidebar and main content -->
        <Grid Grid.Row="1" ColumnDefinitions="Auto,Auto,*" HorizontalAlignment="Stretch">
            <!-- Sidebar -->
            <Border Grid.Column="0" Background="#212121"
                    Padding="10"
                    MinWidth="150"
                    Width="250">
                <DockPanel>
                    
                    <!-- Search Bar -->
                    <TextBox DockPanel.Dock="Top"
                             Text="{Binding PlaylistViewModel.PlaylistSearchQuery}"
                             Watermark="Search playlists..."
                             VerticalAlignment="Center"
                             Background="#333333"
                             BorderThickness="0"
                             Padding="10"
                             Foreground="White"
                             CaretBrush="White" />
                        
                    
                    <TextBlock DockPanel.Dock="Top" Text="Your Playlists" FontSize="16" FontWeight="SemiBold"
                               Margin="10" Foreground="White" HorizontalAlignment="Center" />

                    <ProgressBar DockPanel.Dock="Top" IsIndeterminate="True" IsVisible="{Binding PlaylistViewModel.IsLoadingPlaylists}"
                                 Height="4" Margin="0,5,0,10" Foreground="#1DB954" />

                    <!-- Playlists List - Add SelectedItem binding -->
                    <ListBox ItemsSource="{Binding PlaylistViewModel.FilteredPlaylists}"
                             SelectedItem="{Binding PlaylistViewModel.SelectedPlaylist}"
                             SelectionMode="Toggle"
                             Background="Transparent"
                             Padding="0"
                             IsVisible="{Binding IsAuthenticated}">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="models:PlaylistModel">
                                <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,5">
                                    <!-- Handle a potential null or empty Images collection -->
                                    <Border Width="40" Height="40" Background="#333333" CornerRadius="4">
                                        <Panel>
                                            <!-- Show the first letter as fallback -->
                                            <TextBlock Text="{Binding Name[0], FallbackValue='?'}"
                                                       VerticalAlignment="Center"
                                                       HorizontalAlignment="Center"
                                                       Foreground="White"
                                                       FontWeight="Bold" />

                                            <!-- Show image if available, it will overlay the text -->
                                            <Image
                                                asyncImage:ImageLoader.Source="{Binding ImageUrl, FallbackValue=''}"
                                                Stretch="UniformToFill"
                                                IsVisible="{Binding ImageUrl, Converter={x:Static ObjectConverters.IsNotNull}}" />
                                        </Panel>
                                    </Border>
                                    <TextBlock Text="{Binding Name}" VerticalAlignment="Center" Foreground="White" />
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <GridSplitter Grid.Column="1" Width="5" Background="#333333" ResizeDirection="Columns" />

            <!-- Main Content Area -->
            <Border Grid.Column="2" Background="#121212"
                    Padding="20">
                <Grid RowDefinitions="Auto,*">
                    <!-- Content Header - Show selected playlist name -->
                    <TextBlock Grid.Row="0"
                               Text="{Binding TrackListViewModel.CurrentPlaylist.Name, FallbackValue='Select a playlist to clean'}"
                               FontSize="24"
                               TextTrimming="CharacterEllipsis"
                               TextWrapping="NoWrap"
                               FontWeight="Bold"
                               Margin="0,0,0,20"
                               Foreground="White"
                               IsVisible="{Binding IsAuthenticated}" />

                    <!-- Playlist content when selected -->
                    <Grid Grid.Row="1"
                          IsVisible="{Binding TrackListViewModel.CurrentPlaylist, Converter={x:Static ObjectConverters.IsNotNull}}"
                          RowDefinitions="Auto,Auto,*">

                        <!-- Description -->
                        <TextBlock Grid.Row="0"
                                   Text="{Binding TrackListViewModel.CurrentPlaylist.Description, FallbackValue='No description available'}"
                                   Foreground="#B3B3B3"
                                   Margin="0,0,0,15"
                                   TextWrapping="Wrap" />

                        <!-- Actions and Search - Common for both views -->
                        <Grid Grid.Row="1" Margin="0,0,0,15" RowDefinitions="Auto,0" ColumnDefinitions="Auto,Auto,*">
                            <!-- Action Buttons (Left) -->
                            <Panel Grid.Column="0" Grid.Row="0">
                                <!-- Track list view buttons -->
                                <StackPanel Orientation="Horizontal" Spacing="10" IsVisible="{Binding DuplicatesViewModel.IsDuplicatesViewVisible, Converter={x:Static BoolConverters.Not}}">
                                    <Button Content="Remove Duplicates"
                                            Command="{Binding FindDuplicatesCommand}"
                                            Background="#1DB954"
                                            Foreground="White"
                                            Padding="15,8" />
                                    <Button Content="Reset Filters"
                                            Command="{Binding TrackListViewModel.ResetFiltersCommand}"
                                            Background="#333333"
                                            Foreground="White"
                                            Padding="15,8" />
                                </StackPanel>
                                
                                <!-- Duplicates view buttons -->
                                <StackPanel Orientation="Horizontal" Spacing="10" IsVisible="{Binding DuplicatesViewModel.IsDuplicatesViewVisible}">
                                    <Button Content="Back to Tracks"
                                            Command="{Binding DuplicatesViewModel.BackToTracksCommand}"
                                            Background="#333333"
                                            Foreground="White"
                                            Padding="15,8" />
                                    <Button Content="Reset Filters"
                                            Command="{Binding DuplicatesViewModel.ResetFiltersCommand}"
                                            Background="#333333"
                                            Foreground="White"
                                            Padding="15,8" />
                                </StackPanel>
                            </Panel>

                            <!-- Spacer (To separate buttons from search) -->
                            <Border Grid.Column="1" Grid.Row="0" Width="20" />

                            <!-- Search Bar (Right) - Shared between both views -->
                            <Border Grid.Column="2"
                                    Grid.Row="0"
                                    Background="#333333"
                                    CornerRadius="4"
                                    Height="34"
                                    Margin="0">
                                <Grid ColumnDefinitions="Auto,*">
                                    <!-- Search Icon -->
                                    <Path Grid.Column="0"
                                          Data="M9.5,3A6.5,6.5 0 0,1 16,9.5C16,11.11 15.41,12.59 14.44,13.73L14.71,14H15.5L20.5,19L19,20.5L14,15.5V14.71L13.73,14.44C12.59,15.41 11.11,16 9.5,16A6.5,6.5 0 0,1 3,9.5A6.5,6.5 0 0,1 9.5,3M9.5,5C7,5 5,7 5,9.5C5,12 7,14 9.5,14C12,14 14,9.5 14,9.5C14,7 12,5 9.5,5Z"
                                          Fill="#B3B3B3"
                                          Width="16"
                                          Height="16"
                                          Margin="8,0,12,8"
                                          VerticalAlignment="Center" />

                                    <!-- TextBox for track list view -->
                                    <TextBox Grid.Column="1"
                                             Text="{Binding TrackListViewModel.SearchQuery}"
                                             Watermark="Search tracks..."
                                             VerticalAlignment="Center"
                                             Background="Transparent"
                                             BorderThickness="0"
                                             Padding="8,8,8,8"
                                             Foreground="White"
                                             CaretBrush="White"
                                             IsVisible="{Binding DuplicatesViewModel.IsDuplicatesViewVisible, Converter={x:Static BoolConverters.Not}}" />
                                             
                                    <!-- TextBox for duplicates view -->
                                    <TextBox Grid.Column="1"
                                             Text="{Binding DuplicatesViewModel.SearchQuery}"
                                             Watermark="Search duplicates..."
                                             VerticalAlignment="Center"
                                             Background="Transparent"
                                             BorderThickness="0"
                                             Padding="8,8,8,8"
                                             Foreground="White"
                                             CaretBrush="White"
                                             IsVisible="{Binding DuplicatesViewModel.IsDuplicatesViewVisible}" />
                                </Grid>
                            </Border>
                        </Grid>

                        <!-- Loading indicators - Show when tracks are loading -->
                        <Grid Grid.Row="2"
                              VerticalAlignment="Center"
                              HorizontalAlignment="Center"
                              IsVisible="{Binding TrackListViewModel.IsLoadingTracks}">
                            <StackPanel Spacing="20" Width="300">
                                <!-- Spinner with animation -->
                                <Panel HorizontalAlignment="Center" Margin="0,0,0,10">
                                    <Border Width="50" Height="50"
                                            CornerRadius="25"
                                            Background="Transparent"
                                            BorderBrush="#1DB954"
                                            BorderThickness="4"
                                            IsHitTestVisible="False">
                                        <Border.Styles>
                                            <Style Selector="Border">
                                                <Setter Property="RenderTransform">
                                                    <RotateTransform />
                                                </Setter>
                                                <Style.Animations>
                                                    <Animation Duration="0:0:1"
                                                               IterationCount="Infinite">
                                                        <KeyFrame Cue="0">
                                                            <Setter Property="RotateTransform.Angle" Value="0" />
                                                        </KeyFrame>
                                                        <KeyFrame Cue="1">
                                                            <Setter Property="RotateTransform.Angle" Value="360" />
                                                        </KeyFrame>
                                                    </Animation>
                                                </Style.Animations>
                                            </Style>
                                        </Border.Styles>
                                    </Border>

                                    <TextBlock Text="{Binding TrackListViewModel.LoadingProgress, StringFormat=\{0\}%}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Foreground="White" />
                                </Panel>

                                <!-- Progress Bar -->
                                <ProgressBar Value="{Binding TrackListViewModel.LoadingProgress}"
                                             Maximum="100"
                                             Height="6"
                                             Foreground="#1DB954" />

                                <!-- Status Text -->
                                <TextBlock Text="{Binding TrackListViewModel.LoadingStatusMessage}"
                                           HorizontalAlignment="Center"
                                           Foreground="#B3B3B3" />
                            </StackPanel>
                        </Grid>

                        <Grid Grid.Row="2" IsVisible="{Binding DuplicatesViewModel.IsDuplicatesViewVisible}" RowDefinitions="Auto,*,Auto">
                            <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="10">
                                <TextBlock Text="Duplicate Tracks" FontWeight="Bold" FontSize="16"
                                           VerticalAlignment="Center" />
                                <TextBlock Text="{Binding DuplicatesViewModel.DuplicateGroups.Count, StringFormat=': {0} groups found'}"
                                           VerticalAlignment="Center" />
                            </StackPanel>

                            <ScrollViewer Grid.Row="1" Margin="0,10,0,10">
                                <ItemsControl ItemsSource="{Binding DuplicatesViewModel.FilteredDuplicateGroups}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="models:DuplicateGroup">
                                            <Border Background="#1A1A1A" CornerRadius="6" Margin="0,4" Padding="0">
                                                <Expander IsExpanded="False" HorizontalAlignment="Stretch">
                                                    <Expander.Header>
                                                        <Grid ColumnDefinitions="Auto,*,Auto,Auto" Margin="4,2" HorizontalAlignment="Stretch">
                                                            <!-- Album Image -->
                                                            <Border Grid.Column="0" Width="40" Height="40" Background="#333333" CornerRadius="4" Margin="0,0,10,0">
                                                                <Panel>
                                                                    <TextBlock Text="{Binding DisplayName[0], FallbackValue='?'}"
                                                                               VerticalAlignment="Center"
                                                                               HorizontalAlignment="Center"
                                                                               Foreground="White"
                                                                               FontWeight="Bold" />
                                                                    <Image asyncImage:ImageLoader.Source="{Binding DisplayImage}"
                                                                           Stretch="UniformToFill"
                                                                           IsVisible="{Binding DisplayImage, Converter={x:Static ObjectConverters.IsNotNull}}" />
                                                                </Panel>
                                                            </Border>
                                                            <!-- Group Info -->
                                                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="4,0">
                                                                <TextBlock Text="{Binding DisplayName}" Foreground="White" FontWeight="SemiBold" FontSize="14"
                                                                           TextTrimming="CharacterEllipsis" />
                                                                <TextBlock Text="{Binding DisplayArtist}" Foreground="#B3B3B3" FontSize="12"
                                                                           TextTrimming="CharacterEllipsis" />
                                                            </StackPanel>
                                                            <!-- Count -->
                                                            <TextBlock Grid.Column="2" VerticalAlignment="Center" Foreground="#B3B3B3" Margin="10,0"
                                                                       Text="{Binding DuplicateCount, StringFormat='{}{0} track(s)'}" />
                                                            <!-- Delete Group Button -->
                                                            <Button Grid.Column="3" Background="Transparent" BorderThickness="0"
                                                                    Padding="8,4" VerticalAlignment="Center"
                                                                    Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).DuplicatesViewModel.DeleteGroupDuplicatesCommand}"
                                                                    CommandParameter="{Binding}">
                                                                <TextBlock Text="Delete Duplicates" FontSize="12" Foreground="#ff5252" />
                                                            </Button>
                                                        </Grid>
                                                    </Expander.Header>

                                                    <!-- Child tracks -->
                                                    <ItemsControl ItemsSource="{Binding Tracks}" Margin="20,0,0,8">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate x:DataType="models:TrackModel">
                                                                <Border Background="#222222" CornerRadius="4" Margin="0,2" Padding="8,6">
                                                                    <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto,Auto">
                                                                        <!-- Track Album Image -->
                                                                        <Border Grid.Column="0" Width="36" Height="36" Background="#333333" CornerRadius="4" Margin="0,0,10,0">
                                                                            <Panel>
                                                                                <TextBlock Text="{Binding Name[0], FallbackValue='?'}"
                                                                                           VerticalAlignment="Center"
                                                                                           HorizontalAlignment="Center"
                                                                                           Foreground="White"
                                                                                           FontWeight="Bold"
                                                                                           FontSize="10" />
                                                                                <Image asyncImage:ImageLoader.Source="{Binding AlbumImageUrl}"
                                                                                       Stretch="UniformToFill"
                                                                                       IsVisible="{Binding AlbumImageUrl, Converter={x:Static ObjectConverters.IsNotNull}}" />
                                                                            </Panel>
                                                                        </Border>
                                                                        <!-- Track Info -->
                                                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="4,0">
                                                                            <StackPanel Orientation="Horizontal" Spacing="5">
                                                                                <TextBlock Text="{Binding Name}" Foreground="White" FontSize="13"
                                                                                           TextTrimming="CharacterEllipsis" />
                                                                                <Border Background="#333333" CornerRadius="2" Padding="3,2"
                                                                                        IsVisible="{Binding IsExplicit}">
                                                                                    <TextBlock Text="Explicit" FontSize="9" Foreground="#B3B3B3" />
                                                                                </Border>
                                                                                <Border Background="#333333" CornerRadius="2" Padding="3,2"
                                                                                        IsVisible="{Binding IsLocal}">
                                                                                    <TextBlock Text="Local" FontSize="9" Foreground="#B3B3B3" />
                                                                                </Border>
                                                                            </StackPanel>
                                                                            <TextBlock Text="{Binding ArtistNames}" Foreground="#B3B3B3" FontSize="11"
                                                                                       TextTrimming="CharacterEllipsis" />
                                                                        </StackPanel>
                                                                        <!-- Duration -->
                                                                        <TextBlock Grid.Column="2" Text="{Binding Duration}" Foreground="#B3B3B3"
                                                                                   VerticalAlignment="Center" Margin="10,0" FontSize="12" />
                                                                        <!-- Playlist Position -->
                                                                        <TextBlock Grid.Column="3" Text="{Binding PlaylistPosition}" Foreground="#666666"
                                                                                   VerticalAlignment="Center" Margin="10,0" FontSize="11" />
                                                                        <!-- Delete Track Button -->
                                                                        <Button Grid.Column="5" Background="Transparent" BorderThickness="0"
                                                                                Width="32" Height="32" Padding="0"
                                                                                HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                        Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).DuplicatesViewModel.DeleteDuplicateCommand}"
                                                                                CommandParameter="{Binding}"
                                                                                ToolTip.Tip="Delete Track">
                                                                            <Viewbox Width="16" Height="16" Margin="-2,-2,2,2">
                                                                                <Path Data="M6,19C6,20.1 6.9,21 8,21H16C17.1,21 18,20.1 18,19V7H6V19M19,4H15.5L14.5,3H9.5L8.5,4H5V6H19V4Z"
                                                                                      Fill="#ff5252" />
                                                                            </Viewbox>
                                                                        </Button>
                                                                    </Grid>
                                                                </Border>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </Expander>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>

                            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right"
                                        Margin="0,10,0,0">
                                <Button Content="Remove All Duplicates"
                                        Command="{Binding DuplicatesViewModel.RemoveAllDuplicatesCommand}" />
                            </StackPanel>
                        </Grid>

                        <!-- Update your DataGrid to only show when the duplicates view is not visible -->
                        <DataGrid Grid.Row="2"
                                  ItemsSource="{Binding TrackListViewModel.FilteredTracks}"
                                  IsVisible="{Binding DuplicatesViewModel.IsDuplicatesViewVisible, Converter={x:Static BoolConverters.Not}}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  CanUserResizeColumns="True">
                            <!-- Keep your existing DataGrid configuration -->
                            <DataGrid.Columns>
                                <!-- Index Column -->
                                <DataGridTemplateColumn Header="#" Width="Auto" MinWidth="40"
                                                        SortMemberPath="DisplayIndex">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate x:DataType="models:TrackModel">
                                            <TextBlock Text="{Binding DisplayIndex}"
                                                       Foreground="#B3B3B3"
                                                       VerticalAlignment="Center"
                                                       HorizontalAlignment="Center"
                                                       FontSize="14" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <!-- Album art Column -->
                                <DataGridTemplateColumn Header="" Width="Auto" MinWidth="50">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate x:DataType="models:TrackModel">
                                            <Border Width="40" Height="40" Background="#333333" CornerRadius="4"
                                                    Margin="5,0">
                                                <Panel>
                                                    <TextBlock Text="{Binding Name[0], FallbackValue='?'}"
                                                               VerticalAlignment="Center"
                                                               HorizontalAlignment="Center"
                                                               Foreground="White"
                                                               FontWeight="Bold" />
                                                    <Image
                                                        asyncImage:ImageLoader.Source="{Binding AlbumImageUrl}"
                                                        Stretch="UniformToFill"
                                                        IsVisible="{Binding AlbumImageUrl, Converter={x:Static ObjectConverters.IsNotNull}}" />
                                                </Panel>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <!-- Track Name Column -->
                                <DataGridTemplateColumn Header="Title" Width="*" MinWidth="120" SortMemberPath="Name">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate x:DataType="models:TrackModel">
                                            <StackPanel VerticalAlignment="Center" Margin="0,5">
                                                <StackPanel Orientation="Horizontal" Spacing="5">
                                                    <TextBlock Text="{Binding Name}" Foreground="White"
                                                               FontSize="14" />
                                                    <Border Background="#333333" CornerRadius="2" Padding="3,3"
                                                            IsVisible="{Binding IsExplicit}">
                                                        <TextBlock Text="Explicit" FontSize="10" Foreground="#B3B3B3" />
                                                    </Border>
                                                    <Border Background="#333333" CornerRadius="2" Padding="3,3"
                                                            IsVisible="{Binding IsLocal}">
                                                        <TextBlock Text="Local" FontSize="10" Foreground="#B3B3B3" />
                                                    </Border>
                                                    <Border Background="#333333" CornerRadius="2" Padding="3,3"
                                                            IsVisible="{Binding !IsPlayable}">
                                                        <TextBlock Text="Not Playable"
                                                                   FontSize="10"
                                                                   Foreground="#B3B3B3" />
                                                    </Border>
                                                </StackPanel>
                                                <TextBlock Foreground="#B3B3B3"
                                                           FontSize="12">
                                                    <TextBlock.Text>
                                                        <MultiBinding StringFormat="{}{0}">
                                                            <Binding Path="Artists">
                                                                <Binding.Converter>
                                                                    <converters:ArtistListToStringConverter
                                                                        Separator=", " />
                                                                </Binding.Converter>
                                                            </Binding>
                                                        </MultiBinding>
                                                    </TextBlock.Text>
                                                </TextBlock>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <!-- Duration Column -->
                                <DataGridTemplateColumn Header="Duration" Width="Auto" MinWidth="80"
                                                        SortMemberPath="Duration">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate x:DataType="models:TrackModel">
                                            <TextBlock Text="{Binding Duration}"
                                                       Foreground="#B3B3B3"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       Margin="0,0,10,0" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <!-- Delete Button Column -->
                                <DataGridTemplateColumn Header="" Width="Auto" MinWidth="50">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate x:DataType="models:TrackModel">
                                            <ContentControl Content="{Binding}"
                                                            ContentTemplate="{StaticResource DeleteButtonTemplate}" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>


                            <!-- Styling -->
                            <DataGrid.Styles>
                                <!-- Row styling -->
                                <Style Selector="DataGridRow">
                                    <Setter Property="Background" Value="Transparent" />
                                </Style>
                                <!-- Header styling -->
                                <Style Selector="DataGridColumnHeader">
                                    <Setter Property="Background" Value="#212121" />
                                    <Setter Property="Foreground" Value="#B3B3B3" />
                                    <Setter Property="FontWeight" Value="SemiBold" />
                                    <Setter Property="Padding" Value="10,8" />
                                </Style>
                                <!-- Selected row styling -->
                                <Style Selector="DataGridRow:selected">
                                    <Setter Property="Background" Value="#333333" />
                                </Style>
                                <!-- Remove focus visuals -->
                                <Style Selector="DataGrid:focus DataGridCell:current">
                                    <Setter Property="BorderBrush" Value="Transparent" />
                                </Style>
                            </DataGrid.Styles>
                        </DataGrid>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
