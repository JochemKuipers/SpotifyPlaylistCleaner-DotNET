<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:SpotifyPlaylistCleaner_DotNET.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:spotify="using:SpotifyAPI.Web"
        xmlns:asyncImage="using:AsyncImageLoader"
        xmlns:converters="using:SpotifyPlaylistCleaner_DotNET.Converters"
        mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="600"
        x:Class="SpotifyPlaylistCleaner_DotNET.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="Spotify Playlist Cleaner"
        Background="#121212">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Grid RowDefinitions="Auto,*">
        <!-- Header -->
        <Border Grid.Row="0" Grid.ColumnSpan="2" Background="#1DB954" Padding="15" BoxShadow="0 1 10 0 #20000000">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <!-- App Title (Left) -->
                <StackPanel Orientation="Horizontal" Grid.Column="0" Spacing="10" VerticalAlignment="Center">
                    <TextBlock Text="Spotify Playlist Cleaner" FontSize="20" FontWeight="Bold" Foreground="White"/>
                </StackPanel>
                
                <!-- Status Message (Center - properly aligned) -->
                <Grid Grid.Column="0" Grid.ColumnSpan="3" VerticalAlignment="Center">
                    <TextBlock Text="{Binding StatusMessage}" 
                            HorizontalAlignment="Center"
                            TextAlignment="Center"
                            Foreground="White" 
                            MaxWidth="500"/>
                </Grid>
                
                <!-- Login Button (Right) -->
                <Button Grid.Column="2" Content="Login with Spotify" 
                        Command="{Binding AuthenticateCommand}"
                        IsEnabled="{Binding !IsAuthenticating}"
                        IsVisible="{Binding !IsAuthenticated}"
                        Padding="10,5"
                        Background="#121212"
                        Foreground="White"/>
            </Grid>
        </Border>

        <!-- Content area with sidebar and main content -->
        <Grid Grid.Row="1" ColumnDefinitions="250,*">
            <!-- Sidebar -->
            <Border Grid.Column="0" Background="#212121" Padding="10">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="Your Playlists" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10" Foreground="White"/>
                    
                    <ProgressBar DockPanel.Dock="Top" IsIndeterminate="True" IsVisible="{Binding IsLoadingPlaylists}" 
                                 Height="4" Margin="0,5,0,10" Foreground="#1DB954"/>
                    
                    <!-- Playlists List - Add SelectedItem binding -->
                    <ListBox ItemsSource="{Binding Playlists}" 
                             SelectedItem="{Binding SelectedPlaylist}"
                             Background="Transparent" 
                             Padding="0"
                             IsVisible="{Binding IsAuthenticated}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,5">
                                    <!-- Handle potential null or empty Images collection -->
                                    <Border Width="40" Height="40" Background="#333333" CornerRadius="4">
                                        <Panel>
                                            <!-- Show the first letter as fallback -->
                                            <TextBlock Text="{Binding Name[0]}" 
                                                    VerticalAlignment="Center" 
                                                    HorizontalAlignment="Center"
                                                    Foreground="White" 
                                                    FontWeight="Bold"/>
                                                    
                                            <!-- Show image if available, it will overlay the text -->
                                            <Image asyncImage:ImageLoader.Source="{Binding Images[0].Url}"
                                                Stretch="UniformToFill"
                                                IsVisible="{Binding Images, Converter={x:Static ObjectConverters.IsNotNull}}"/> 
                                        </Panel>
                                    </Border>
                                    <TextBlock Text="{Binding Name}" VerticalAlignment="Center" Foreground="White"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <!-- Main Content Area -->
            <Border Grid.Column="1" Background="#121212" Padding="20">
                <Grid RowDefinitions="Auto,*">
                    <!-- Content Header - Show selected playlist name -->
                    <TextBlock Grid.Row="0" 
                              Text="{Binding SelectedPlaylist.Name, FallbackValue='Select a playlist to clean'}" 
                              FontSize="24" 
                              FontWeight="Bold" 
                              Margin="0,0,0,20" 
                              Foreground="White"
                              IsVisible="{Binding IsAuthenticated}"/>
                    
                    <!-- Playlist content when selected -->
                    <Grid Grid.Row="1" IsVisible="{Binding SelectedPlaylist, Converter={x:Static ObjectConverters.IsNotNull}}"
                          RowDefinitions="Auto,Auto,*">
                          
                        <!-- Description -->
                        <TextBlock Grid.Row="0"
                                  Text="{Binding SelectedPlaylist.Description}" 
                                  Foreground="#B3B3B3" 
                                  Margin="0,0,0,15"
                                  TextWrapping="Wrap"/>
                                  
                        <!-- Actions -->
                        <StackPanel Grid.Row="1" 
                                   Orientation="Horizontal" 
                                   Spacing="10"
                                   Margin="0,0,0,15">
                            <Button Content="Remove Duplicates" 
                                    Background="#1DB954" 
                                    Foreground="White" 
                                    Padding="15,8"/>
                            <Button Content="Sort Tracks" 
                                    Background="#333333" 
                                    Foreground="White" 
                                    Padding="15,8"/>
                        </StackPanel>

                        <!-- Track List - Now in a row with * height which means "take all remaining space" -->
                        <ListBox Grid.Row="2"
                                ItemsSource="{Binding Tracks}" 
                                Background="Transparent" 
                                Padding="0"
                                ScrollViewer.VerticalScrollBarVisibility="Auto"
                                IsVisible="{Binding Tracks, Converter={x:Static ObjectConverters.IsNotNull}}">
                            <!-- Keep your existing ListBox.ItemTemplate -->
                            <ListBox.ItemTemplate>
                                <DataTemplate x:DataType="spotify:FullTrack">
                                    <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,5">
                                        <Border Width="40" Height="40" Background="#333333" CornerRadius="4">
                                            <Panel>
                                                <!-- Show the first letter as fallback -->
                                                <TextBlock Text="{Binding Name[0]}" 
                                                        VerticalAlignment="Center" 
                                                        HorizontalAlignment="Center"
                                                        Foreground="White" 
                                                        FontWeight="Bold"/>
                                                
                                                <!-- Show image if available, it will overlay the text -->
                                                <Image asyncImage:ImageLoader.Source="{Binding Album.Images[0].Url}"
                                                    Stretch="UniformToFill"
                                                    IsVisible="{Binding Album.Images, Converter={x:Static ObjectConverters.IsNotNull}}"/> 
                                            </Panel>
                                        </Border>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Name}" Foreground="White"/>
                                            <TextBlock Foreground="#B3B3B3" FontSize="12">
                                                <TextBlock.Text>
                                                    <MultiBinding StringFormat="{}{0}">
                                                        <Binding Path="Artists">
                                                            <Binding.Converter>
                                                                <converters:ArtistListToStringConverter Separator=", " />
                                                            </Binding.Converter>
                                                        </Binding>
                                                    </MultiBinding>
                                                </TextBlock.Text>
                                            </TextBlock>
                                        </StackPanel>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                    
                    <!-- Placeholder when no playlist selected -->
                    <TextBlock Grid.Row="1" 
                              Text="Select a playlist from the sidebar to view and clean it" 
                              VerticalAlignment="Center" 
                              HorizontalAlignment="Center"
                              Foreground="#B3B3B3" 
                              IsVisible="{Binding SelectedPlaylist, Converter={x:Static ObjectConverters.IsNull}}"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
