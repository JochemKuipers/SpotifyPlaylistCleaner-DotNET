<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:SpotifyPlaylistCleaner_DotNET.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:asyncImage="using:AsyncImageLoader"
        xmlns:converters="using:SpotifyPlaylistCleaner_DotNET.Converters"
        mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="600"
        x:Class="SpotifyPlaylistCleaner_DotNET.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/Icons/icon.ico"
        Title="Spotify Playlist Cleaner"
        Background="#121212">

  <Design.DataContext>
        <vm:MainWindowViewModel />
    </Design.DataContext>

    <Grid RowDefinitions="Auto,*">
        <!-- Header -->
        <Border Grid.Row="0" Grid.ColumnSpan="2" Background="#1DB954" Padding="{OnFormFactor Default='20,20,20,20', Mobile='10,10,10,10'}" BoxShadow="0 1 10 0 #20000000">
          <Grid ColumnDefinitions="Auto,*,Auto">
                <!-- App Title (Left) -->
                <StackPanel Orientation="Horizontal" Grid.Column="0" Spacing="10" VerticalAlignment="Center">
                    <TextBlock Text="Spotify Playlist Cleaner" FontSize="20" FontWeight="Bold" Foreground="White" />
                </StackPanel>

                <!-- Status Message (Center - properly aligned) -->
                <Grid Grid.Column="0" Grid.ColumnSpan="3" VerticalAlignment="Center">
                    <TextBlock Text="{Binding StatusMessage}"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"
                               Foreground="White"
                               MaxWidth="500" />
                </Grid>

                <!-- Right side controls -->
                <Panel Grid.Column="2">
                    <!-- Desktop layout (horizontal) -->
                    <StackPanel Orientation="Horizontal" Spacing="10" IsVisible="{OnFormFactor Default=true, Mobile=false}">
                        <!-- Refresh Cache Button -->
                        <Button Command="{Binding RefreshTracksCommand}"
                                CommandParameter="{Binding SelectedPlaylist, Converter={x:Static ObjectConverters.IsNull}}"
                                IsEnabled="{Binding IsAuthenticated}"
                                ToolTip.Tip="Refresh Tracks"
                                Padding="10,5"
                                Background="#121212"
                                Foreground="White">
                            <StackPanel Orientation="Horizontal" Spacing="5">
                                <Path Data="M17.65,6.35C16.2,4.9 14.21,4 12,4A8,8 0 0,0 4,12A8,8 0 0,0 12,20A8,8 0 0,0 20,12H18A6,6 0 0,1 12,18A6,6 0 0,1 6,12A6,6 0 0,1 12,6C13.66,6 15.14,6.69 16.22,7.78L13,11H20V4L17.65,6.35Z"
                                      Fill="White" Width="16" Height="16" Stretch="Uniform" />
                                <TextBlock Text="Refresh Tracks" />
                            </StackPanel>
                        </Button>

                        <!-- Login Button -->
                        <Button Content="Login with Spotify"
                                Command="{Binding AuthenticateCommand}"
                                IsEnabled="{Binding !IsAuthenticating}"
                                IsVisible="{Binding !IsAuthenticated}"
                                Padding="10,5"
                                Background="#121212"
                                Foreground="White" />
                    </StackPanel>

                    <!-- Mobile layout (vertical) -->
                    <StackPanel Orientation="Vertical" Spacing="5" IsVisible="{OnFormFactor Default=false, Mobile=true}">
                        <!-- Refresh Cache Button -->
                        <Button Command="{Binding RefreshTracksCommand}"
                                CommandParameter="{Binding SelectedPlaylist, Converter={x:Static ObjectConverters.IsNull}}"
                                IsEnabled="{Binding IsAuthenticated}"
                                ToolTip.Tip="Refresh Tracks"
                                Padding="10,5"
                                Background="#121212"
                                Foreground="White">
                            <StackPanel Orientation="Horizontal" Spacing="5">
                                <Path Data="M17.65,6.35C16.2,4.9 14.21,4 12,4A8,8 0 0,0 4,12A8,8 0 0,0 12,20A8,8 0 0,0 20,12H18A6,6 0 0,1 12,18A6,6 0 0,1 6,12A6,6 0 0,1 12,6C13.66,6 15.14,6.69 16.22,7.78L13,11H20V4L17.65,6.35Z"
                                      Fill="White" Width="16" Height="16" Stretch="Uniform" />
                                <TextBlock Text="Refresh Tracks" />
                            </StackPanel>
                        </Button>

                        <!-- Login Button -->
                        <Button Content="Login with Spotify"
                                Command="{Binding AuthenticateCommand}"
                                IsEnabled="{Binding !IsAuthenticating}"
                                IsVisible="{Binding !IsAuthenticated}"
                                Padding="10,5"
                                Background="#121212"
                                Foreground="White" />
                    </StackPanel>
                </Panel>
            </Grid>
        </Border>

        <!-- Content area with sidebar and main content -->
        <Grid Grid.Row="1" ColumnDefinitions="Auto,Auto,*" HorizontalAlignment="Stretch">
            <!-- Sidebar -->
            <Border Grid.Column="0" Background="#212121" Padding="{OnFormFactor Default='10,10,10,10', Mobile='5,5,5,5'}" MinWidth="{OnFormFactor Default='150', Mobile='100'}" Width="{OnFormFactor Default='250', Mobile='200'}">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="Your Playlists" FontSize="16" FontWeight="SemiBold"
                               Margin="0,0,0,10" Foreground="White" />

                    <ProgressBar DockPanel.Dock="Top" IsIndeterminate="True" IsVisible="{Binding IsLoadingPlaylists}"
                                 Height="4" Margin="0,5,0,10" Foreground="#1DB954" />

                    <!-- Playlists List - Add SelectedItem binding -->
                    <ListBox ItemsSource="{Binding Playlists}"
                             SelectedItem="{Binding SelectedPlaylist}"
                             SelectionMode="Toggle"
                             Background="Transparent"
                             Padding="0"
                             IsVisible="{Binding IsAuthenticated}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,5">
                                    <!-- Handle potential null or empty Images collection -->
                                    <Border Width="40" Height="40" Background="#333333" CornerRadius="4">
                                        <Panel>
                                            <!-- Show the first letter as fallback -->
                                            <TextBlock Text="{Binding Name[0], FallbackValue='?'}"
                                                       VerticalAlignment="Center"
                                                       HorizontalAlignment="Center"
                                                       Foreground="White"
                                                       FontWeight="Bold" />

                                            <!-- Show image if available, it will overlay the text -->
                                            <Image
                                                asyncImage:ImageLoader.Source="{Binding Images[0].Url, FallbackValue=''}"
                                                Stretch="UniformToFill"
                                                IsVisible="{Binding Images, Converter={x:Static ObjectConverters.IsNotNull}}" />
                                        </Panel>
                                    </Border>
                                    <TextBlock Text="{Binding Name}" VerticalAlignment="Center" Foreground="White" />
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <GridSplitter Grid.Column="1" Width="5" Background="#333333" ResizeDirection="Columns" />

            <!-- Main Content Area -->
            <Border Grid.Column="2" Background="#121212" Padding="{OnFormFactor Default='20,20,20,20', Mobile='10,10,10,10'}">
                <Grid RowDefinitions="Auto,*">
                    <!-- Content Header - Show selected playlist name -->
                    <TextBlock Grid.Row="0"
                               Text="{Binding SelectedPlaylist.Name, FallbackValue='Select a playlist to clean'}"
                               FontSize="{OnFormFactor Default='24', Mobile='20'}"
                               TextTrimming="CharacterEllipsis"
                               TextWrapping="NoWrap"
                               FontWeight="Bold"
                               Margin="0,0,0,20"
                               Foreground="White"
                               IsVisible="{Binding IsAuthenticated}" />

                    <!-- Playlist content when selected -->
                    <Grid Grid.Row="1"
                          IsVisible="{Binding SelectedPlaylist, Converter={x:Static ObjectConverters.IsNotNull}}"
                          RowDefinitions="Auto,Auto,*">

                        <!-- Description -->
                        <TextBlock Grid.Row="0"
                                   Text="{Binding SelectedPlaylist.Description, FallbackValue='No description available'}"
                                   Foreground="#B3B3B3"
                                   Margin="0,0,0,15"
                                   TextWrapping="Wrap" />

                        <!-- Actions and Search -->
                        <Grid Grid.Row="1" Margin="0,0,0,15">
                          <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="{OnFormFactor Default='Auto', Mobile='*'}" />
                            <ColumnDefinition Width="{OnFormFactor Default='Auto', Mobile='0'}" />
                            <ColumnDefinition Width="{OnFormFactor Default='*', Mobile='0'}" />
                          </Grid.ColumnDefinitions>
                          <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="{OnFormFactor Default='0', Mobile='Auto'}" />
                          </Grid.RowDefinitions>
                          <!-- Action Buttons (Left) -->
                            <Panel Grid.Column="0" Grid.Row="0">
                              <!-- Desktop layout (horizontal) -->
                              <StackPanel Orientation="Horizontal" Spacing="10" IsVisible="{OnFormFactor Default=true, Mobile=false}">
                                <Button Content="Remove Duplicates"
                                        Background="#1DB954"
                                        Foreground="White"
                                        Padding="15,8" />
                                <Button Content="Reset Filters"
                                        Command="{Binding ResetFiltersCommand}"
                                        Background="#333333"
                                        Foreground="White"
                                        Padding="15,8" />
                              </StackPanel>

                              <!-- Mobile layout (vertical) -->
                              <StackPanel Orientation="Vertical" Spacing="5" IsVisible="{OnFormFactor Default=false, Mobile=true}">
                                <Button Content="Remove Duplicates"
                                        Background="#1DB954"
                                        Foreground="White"
                                        Padding="15,8"
                                        HorizontalAlignment="Stretch" />
                                <Button Content="Reset Filters"
                                        Command="{Binding ResetFiltersCommand}"
                                        Background="#333333"
                                        Foreground="White"
                                        Padding="15,8"
                                        HorizontalAlignment="Stretch" />
                              </StackPanel>
                            </Panel>

                            <!-- Spacer (To separate buttons from search) -->
                            <Border Grid.Column="1" Grid.Row="0" Width="20" IsVisible="{OnFormFactor Default=true, Mobile=false}" />

                            <!-- Search Bar (Right) -->
                            <Border Grid.Column="{OnFormFactor Default='2', Mobile='0'}"
                                    Grid.Row="{OnFormFactor Default='0', Mobile='1'}"
                                    Background="#333333"
                                    CornerRadius="4"
                                    Height="34"
                                    Margin="{OnFormFactor Default='0', Mobile='0,10,0,0'}">
                                <Grid ColumnDefinitions="Auto,*">
                                    <!-- Search Icon -->
                                    <Path Grid.Column="0"
                                          Data="M9.5,3A6.5,6.5 0 0,1 16,9.5C16,11.11 15.41,12.59 14.44,13.73L14.71,14H15.5L20.5,19L19,20.5L14,15.5V14.71L13.73,14.44C12.59,15.41 11.11,16 9.5,16A6.5,6.5 0 0,1 3,9.5A6.5,6.5 0 0,1 9.5,3M9.5,5C7,5 5,7 5,9.5C5,12 7,14 9.5,14C12,14 14,12 14,9.5C14,7 12,5 9.5,5Z"
                                          Fill="#B3B3B3"
                                          Width="16"
                                          Height="16"
                                          Margin="8,0,12,8"
                                          VerticalAlignment="Center" />

                                    <!-- Search TextBox -->
                                    <TextBox Grid.Column="1"
                                             Text="{Binding SearchQuery}"
                                             Watermark="Search tracks..."
                                             VerticalAlignment="Center"
                                             Background="Transparent"
                                             BorderThickness="0"
                                             Padding="8,8,8,8"
                                             Foreground="White"
                                             CaretBrush="White" />
                                </Grid>
                            </Border>
                        </Grid>

                        <!-- Loading indicators - Show when tracks are loading -->
                        <Grid Grid.Row="2"
                              VerticalAlignment="Center"
                              HorizontalAlignment="Center"
                              IsVisible="{Binding IsLoadingTracks}">
                            <StackPanel Spacing="20" Width="300">
                                <!-- Spinner with animation -->
                                <Panel HorizontalAlignment="Center" Margin="0,0,0,10">
                                    <Border Width="50" Height="50"
                                            CornerRadius="25"
                                            Background="Transparent"
                                            BorderBrush="#1DB954"
                                            BorderThickness="4"
                                            IsHitTestVisible="False">
                                        <Border.Styles>
                                            <Style Selector="Border">
                                                <Setter Property="RenderTransform">
                                                    <RotateTransform />
                                                </Setter>
                                                <Style.Animations>
                                                    <Animation Duration="0:0:1"
                                                               IterationCount="Infinite">
                                                        <KeyFrame Cue="0">
                                                            <Setter Property="RotateTransform.Angle" Value="0" />
                                                        </KeyFrame>
                                                        <KeyFrame Cue="1">
                                                            <Setter Property="RotateTransform.Angle" Value="360" />
                                                        </KeyFrame>
                                                    </Animation>
                                                </Style.Animations>
                                            </Style>
                                        </Border.Styles>
                                    </Border>

                                    <TextBlock Text="{Binding LoadingProgress, StringFormat=\{0\}%}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Foreground="White" />
                                </Panel>

                                <!-- Progress Bar -->
                                <ProgressBar Value="{Binding LoadingProgress}"
                                             Maximum="100"
                                             Height="6"
                                             Foreground="#1DB954" />

                                <!-- Status Text -->
                                <TextBlock Text="{Binding LoadingStatusMessage}"
                                           HorizontalAlignment="Center"
                                           Foreground="#B3B3B3" />
                            </StackPanel>
                        </Grid>

                        <!-- Track List - Show when not loading -->
                        <DataGrid Grid.Row="2"
                                  ItemsSource="{Binding FilteredTracks}"
                                  Background="Transparent"
                                  RowBackground="Transparent"
                                  GridLinesVisibility="None"
                                  BorderThickness="0"
                                  IsReadOnly="True"
                                  AutoGenerateColumns="False"
                                  CanUserReorderColumns="True"
                                  CanUserResizeColumns="True"
                                  CanUserSortColumns="True"
                                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                                  IsVisible="{Binding !IsLoadingTracks}">
                            <DataGrid.Columns>
                                <!-- Index Column -->
                                <DataGridTemplateColumn Header="#" Width="Auto" MinWidth="40" SortMemberPath="DisplayIndex">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate x:DataType="vm:TrackItemViewModel">
                                            <TextBlock Text="{Binding DisplayIndex}"
                                                       Foreground="#B3B3B3"
                                                       VerticalAlignment="Center"
                                                       HorizontalAlignment="Center"
                                                       FontSize="14" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <!-- Album art Column -->
                                <DataGridTemplateColumn Header="" Width="Auto" MinWidth="50">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate x:DataType="vm:TrackItemViewModel">
                                            <Border Width="40" Height="40" Background="#333333" CornerRadius="4"
                                                    Margin="5,0">
                                                <Panel>
                                                    <TextBlock Text="{Binding Name[0], FallbackValue='?'}"
                                                               VerticalAlignment="Center"
                                                               HorizontalAlignment="Center"
                                                               Foreground="White"
                                                               FontWeight="Bold" />
                                                    <Image
                                                        asyncImage:ImageLoader.Source="{Binding Album.Images[0].Url}"
                                                        Stretch="UniformToFill"
                                                        IsVisible="{Binding Album.Images, Converter={x:Static ObjectConverters.IsNotNull}}" />
                                                </Panel>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <!-- Track Name Column -->
                                <DataGridTemplateColumn Header="Title" Width="*" MinWidth="120" SortMemberPath="Name">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate x:DataType="vm:TrackItemViewModel">
                                            <StackPanel VerticalAlignment="Center" Margin="0,5">
                                                <StackPanel Orientation="Horizontal" Spacing="5">
                                                    <TextBlock Text="{Binding Name}" Foreground="White" FontSize="{OnFormFactor Default='14', Mobile='13'}" />
                                                    <Border Background="#333333" CornerRadius="2" Padding="3,3" IsVisible="{Binding Explicit}">
                                                        <TextBlock Text="Explicit" FontSize="10" Foreground="#B3B3B3" />
                                                    </Border>
                                                    <Border Background="#333333" CornerRadius="2" Padding="3,3" IsVisible="{Binding IsLocal}">
                                                        <TextBlock Text="Local" FontSize="10" Foreground="#B3B3B3" />
                                                    </Border>
                                                    <Border Background="#333333" CornerRadius="2" Padding="3,3" IsVisible="{Binding !IsPlayable}">
                                                        <TextBlock Text="Not Playable" FontSize="{OnFormFactor Default='10', Mobile='9'}" Foreground="#B3B3B3" />
                                                    </Border>
                                                </StackPanel>
                                                <TextBlock Foreground="#B3B3B3" FontSize="{OnFormFactor Default='12', Mobile='11'}">
                                                    <TextBlock.Text>
                                                        <MultiBinding StringFormat="{}{0}">
                                                            <Binding Path="Artists">
                                                                <Binding.Converter>
                                                                    <converters:ArtistListToStringConverter
                                                                        Separator=", " />
                                                                </Binding.Converter>
                                                            </Binding>
                                                        </MultiBinding>
                                                    </TextBlock.Text>
                                                </TextBlock>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <!-- Duration Column -->
                                <DataGridTemplateColumn Header="Duration" Width="Auto" MinWidth="80" SortMemberPath="Duration">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate x:DataType="vm:TrackItemViewModel">
                                            <TextBlock Text="{Binding Duration}"
                                                       Foreground="#B3B3B3"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       Margin="0,0,10,0" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>

                            <!-- Styling -->
                            <DataGrid.Styles>
                                <!-- Row styling -->
                                <Style Selector="DataGridRow">
                                    <Setter Property="Background" Value="Transparent" />
                                </Style>
                                <!-- Header styling -->
                                <Style Selector="DataGridColumnHeader">
                                    <Setter Property="Background" Value="#212121" />
                                    <Setter Property="Foreground" Value="#B3B3B3" />
                                    <Setter Property="FontWeight" Value="SemiBold" />
                                    <Setter Property="Padding" Value="10,8" />
                                </Style>
                                <!-- Selected row styling -->
                                <Style Selector="DataGridRow:selected">
                                    <Setter Property="Background" Value="#333333" />
                                </Style>
                                <!-- Remove focus visuals -->
                                <Style Selector="DataGrid:focus DataGridCell:current">
                                    <Setter Property="BorderBrush" Value="Transparent" />
                                </Style>
                            </DataGrid.Styles>
                        </DataGrid>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
